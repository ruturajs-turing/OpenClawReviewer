/**
 * Get persona name list for the UI search.
 */
function getPersonaList() {
  var registry = PERSONA_REGISTRY || {};
  var keys = Object.keys(registry);
  var list = [];
  for (var i = 0; i < keys.length; i++) {
    var r = registry[keys[i]];
    list.push({
      key: keys[i],
      name: r.full_name || keys[i],
      job: r.job_title || "",
      city: r.city || "",
      pid: r.persona_id || ""
    });
  }
  list.sort(function(a, b) { return a.name.localeCompare(b.name); });
  return list;
}


/**
 * Lookup persona by task.user_name.
 * Tries exact match first, then normalized (hyphens/spaces), then partial.
 */
function lookupPersona_(task) {
  var registry = PERSONA_REGISTRY || {};
  var userName = (task.user_name || "").trim().toLowerCase();
  if (!userName) return null;

  if (registry[userName]) return registry[userName];

  var normalized = userName.replace(/[-]/g, " ").replace(/\s+/g, " ").trim();
  var keys = Object.keys(registry);

  for (var i = 0; i < keys.length; i++) {
    var keyNorm = keys[i].replace(/[-]/g, " ").replace(/\s+/g, " ").trim();
    if (keyNorm === normalized) return registry[keys[i]];
  }

  var nameParts = normalized.split(" ");
  if (nameParts.length >= 2) {
    var first = nameParts[0];
    var last = nameParts[nameParts.length - 1];
    for (var j = 0; j < keys.length; j++) {
      var kNorm = keys[j].replace(/[-]/g, " ");
      if (kNorm.indexOf(first) !== -1 && kNorm.indexOf(last) !== -1) {
        return registry[keys[j]];
      }
    }
  }

  return null;
}

